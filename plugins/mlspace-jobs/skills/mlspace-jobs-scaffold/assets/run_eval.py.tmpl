"""Submit {{PROJECT_NAME}} evaluation jobs to MLSpace — one job per checkpoint.

By default this discovers ``checkpoint-*`` dirs under --checkpoints_dir and
submits one MLSpace job per (latest) checkpoint; each job re-invokes this same
script with ``--local --checkpoint <path>`` inside the container to run the
actual evaluation. Pass --local to run the in-process loop on the calling host.

Idempotent + dedup-safe, mirroring run_train_jobs.py:
  * skip checkpoints whose result JSONs already exist (unless --force);
  * skip when a job with the same normalized description is already queued.

Reuses the shared ``mls`` library (read-only consumer).

    python scripts/run_eval.py --checkpoints_dir {{ARTIFACTS_ROOT}} \
        --author_name you --telegram_nick you --dry
"""

from __future__ import annotations

import argparse
import json
import os
from pathlib import Path
import re
import shlex
import shutil
import subprocess
import sys

# Per-project instance-type map lives in experiments.py (populated from
# `mls job instance_types` at scaffold time). experiments.py has no mls
# dependency, so importing it here keeps eval's --local path mls-free.
from experiments import INSTANCE_TYPES_BY_NUM_GPUS

DATASETS_DEFAULT = ["{{EVAL_DATASET}}"]  # e.g. "hotpotqa", "musique_ans", ...


# ============================ jobs-mode plumbing ============================
# mls (API + redact) is imported lazily inside _submit_jobs so --local works
# without mls installed.

ARTIFACTS_ROOT = "{{ARTIFACTS_ROOT}}"
STAGING_ROOT = "{{STAGING_ROOT}}"
BASE_IMAGE = "cr.ai.cloud.ru/aicloud-base-images/py3.12-torch2.7.0:0.0.41"
HF_HOME = "{{HF_HOME}}"

# Param-count → GPU band (bf16 fit on one 80GB card + KV-cache headroom).
_GPU_BANDS = ((8e9, 1), (16e9, 2), (30e9, 4))

_JOB_DESC_TAG_RE = re.compile(r"[#@]\S+")


def normalize_job_desc(desc: str) -> str:
    return " ".join(_JOB_DESC_TAG_RE.sub("", desc).split())


def num_gpus_for_params(n: int) -> int:
    for upper, gpus in _GPU_BANDS:
        if n <= upper:
            return gpus
    raise ValueError(f"{n / 1e9:.1f}B params exceeds supported max; add a band.")


def compute_param_count(checkpoint: Path) -> int:
    """Cheapest signal first: safetensors index total_size / 2 (bf16)."""
    idx = checkpoint / "model.safetensors.index.json"
    if idx.exists():
        total = json.loads(idx.read_text()).get("metadata", {}).get("total_size")
        if total:
            return int(total) // 2
    single = checkpoint / "model.safetensors"
    if single.exists():
        return single.stat().st_size // 2
    raise FileNotFoundError(f"Cannot size {checkpoint}: no safetensors.")


def _git(repo_root: str, *args: str) -> str:
    return subprocess.run(
        ["git", "-C", repo_root, *args], capture_output=True, text=True, check=True
    ).stdout.strip()


def stage_repo(repo_root: str, target: str) -> None:
    if os.path.isdir(target):
        print(f"Reusing staged repo at: {target}")
        return
    os.makedirs(os.path.dirname(target), exist_ok=True)
    tmp = f"{target}.tmp.{os.getpid()}"
    if os.path.exists(tmp):
        shutil.rmtree(tmp)
    os.makedirs(tmp)
    subprocess.run(["cp", "-a", os.path.join(repo_root, ".git"), tmp], check=True)
    subprocess.run(["git", "-C", tmp, "reset", "--hard", "HEAD"], check=True)
    try:
        os.rename(tmp, target)
    except OSError:
        shutil.rmtree(tmp, ignore_errors=True)
        if not os.path.isdir(target):
            raise


# ============================== discovery ==================================


def _checkpoint_sort_key(p: Path) -> tuple[int, int | str]:
    m = re.fullmatch(r"checkpoint-(\d+)", p.name)
    return (0, int(m.group(1))) if m else (1, p.name)


def discover_checkpoints(root: Path, latest_only: bool) -> list[Path]:
    raw = sorted(
        (p for p in root.rglob("checkpoint-*") if p.is_dir()),
        key=_checkpoint_sort_key,
    )
    raw = [p for p in raw if (p / "config.json").is_file()]
    if latest_only:
        latest: dict[Path, Path] = {}
        for cp in raw:
            latest[cp.parent] = cp  # sorted → last wins
        return sorted(latest.values(), key=_checkpoint_sort_key)
    return raw


def has_all_results(output_dir: Path, datasets: list[str]) -> bool:
    return all((output_dir / f"{d}.json").exists() for d in datasets)


def parse_args() -> tuple[argparse.Namespace, list[str]]:
    p = argparse.ArgumentParser(description="Launch evaluation over checkpoints.")
    p.add_argument("--checkpoints_dir", default=ARTIFACTS_ROOT)
    p.add_argument("--checkpoint", default=None, help="Single checkpoint (needs --local).")
    p.add_argument("--datasets", nargs="+", default=DATASETS_DEFAULT)
    p.add_argument("--output_subdir", default="evaluation")
    p.add_argument("--all", action="store_true", help="Every checkpoint, not just latest.")
    p.add_argument("--local", action="store_true", help="Run in-process on this host.")
    p.add_argument("--dry", "--dry-run", action="store_true")
    p.add_argument("--force", action="store_true")
    p.add_argument("--profile", default="default")
    p.add_argument("--base_image", default=BASE_IMAGE)
    p.add_argument("--author_name", default=None)
    p.add_argument("--telegram_nick", default=None)
    return p.parse_known_args()


def _run_local(args, extra, checkpoints) -> int:
    for cp in checkpoints:
        out = cp / args.output_subdir
        if has_all_results(out, args.datasets) and not args.force:
            print(f"\033[33mSkip (results exist):\033[0m {cp}")
            continue
        cmd = [
            sys.executable, "{{EVAL_ENTRYPOINT}}",  # e.g. "scripts/eval.py"
            "--model", str(cp), "--datasets", *args.datasets,
            "--output_dir", str(out), *extra,
        ]
        print(f"\033[32mRunning:\033[0m {' '.join(cmd)}")
        if args.dry:
            continue
        rc = subprocess.run(cmd, env=os.environ.copy()).returncode
        if rc != 0:
            return rc
    return 0


def _submit_jobs(args, extra, checkpoints, repo_root) -> int:
    from mls.manager.job.utils import (  # lazy: jobs mode only
        get_in_progress_jobs,
        run_job_with_retry,
        training_job_api_from_profile,
    )

    try:
        from mls.manager.job.redact import redact_payload
    except ImportError:  # older mls without the redact module

        def redact_payload(payload, *, hints=("TOKEN", "SECRET", "KEY", "PASSWORD")):
            env = dict(payload.get("env_variables", {}))
            for k, v in env.items():
                if v and any(h in k.upper() for h in hints):
                    env[k] = "<redacted>"
            return {**payload, "env_variables": env}

    if not args.author_name or not args.telegram_nick:
        print("\033[31mJobs mode needs --author_name and --telegram_nick (or --local).\033[0m")
        return 2

    commit = _git(repo_root, "rev-parse", "HEAD")
    if not args.dry:
        staged = os.path.join(STAGING_ROOT, commit)
        stage_repo(repo_root, staged)
        staged_workdir = staged
    else:
        staged_workdir = os.getcwd()

    client, opts = training_job_api_from_profile(args.profile)
    in_progress = {
        normalize_job_desc(j.get("job_desc", "")) for j in get_in_progress_jobs()
    }

    launched: list[dict] = []
    for cp in checkpoints:
        out = cp / args.output_subdir
        if has_all_results(out, args.datasets) and not args.force:
            print(f"\033[33mSkip (results exist):\033[0m {cp}")
            continue

        num_gpus = num_gpus_for_params(compute_param_count(cp))
        inner = [
            "python", "scripts/run_eval.py", "--local", "--checkpoint", str(cp),
            "--datasets", *args.datasets, "--output_subdir", args.output_subdir,
        ]
        if args.force:
            inner.append("--force")
        script = (
            f"cd {shlex.quote(staged_workdir)}"
            ' && export PYTHONPATH="$WORKDIR:${PYTHONPATH:-}"'
            f" && {shlex.join(inner)}"
        )
        description = f"📐 eval {cp.parent.name}/{cp.name}"
        job_desc = f"{description} #{args.author_name} @{args.telegram_nick}"
        if normalize_job_desc(job_desc) in in_progress:
            print(f"\033[33mSkip (already in queue):\033[0m {job_desc}")
            continue

        payload = {
            "script": script,
            "job_desc": job_desc,
            "env_variables": {
                "HF_HOME": HF_HOME,
                "HF_TOKEN": os.environ.get("HF_TOKEN", ""),
                "WORKDIR": staged_workdir,
            },
            "instance_type": INSTANCE_TYPES_BY_NUM_GPUS[num_gpus],
            "region": opts["region"],
            "type": "binary_exp",
            "shm_size_class": "large",
            "base_image": args.base_image,
            "n_workers": 1,
            "processes_per_worker": 1,
        }
        print(f"\033[32mWould launch [{num_gpus} GPU]:\033[0m {job_desc}")
        print(f"\033[90m  {script}\033[0m")
        if args.dry:
            print(json.dumps(redact_payload(payload), indent=2))
            continue
        result = run_job_with_retry(client, payload, profile=args.profile)
        job_name = result.get("job_name") if isinstance(result, dict) else None
        if job_name:
            launched.append({"job_name": job_name, "description": description, "num_gpus": num_gpus})
        print("result", result)

    print("__EVAL_JOBS_JSON__")
    print(json.dumps({"jobs": launched, "launched": len(launched)}))
    return 0


def main() -> int:
    args, extra = parse_args()
    repo_root = _git(os.getcwd(), "rev-parse", "--show-toplevel")

    if args.checkpoint:
        if not args.local:
            print("\033[31m--checkpoint requires --local.\033[0m")
            return 2
        checkpoints = [Path(args.checkpoint).resolve()]
    else:
        checkpoints = discover_checkpoints(
            Path(args.checkpoints_dir).resolve(), latest_only=not args.all
        )
    if not checkpoints:
        # A fresh project simply has no checkpoints yet — that's a no-op, not an
        # error. Returning 0 keeps a scaffold's `--dry` acceptance check green.
        print(
            f"\033[33mNo checkpoint-* directories under "
            f"{args.checkpoints_dir} yet — nothing to evaluate.\033[0m"
        )
        return 0

    if args.local:
        return _run_local(args, extra, checkpoints)
    return _submit_jobs(args, extra, checkpoints, repo_root)


if __name__ == "__main__":
    sys.exit(main())
