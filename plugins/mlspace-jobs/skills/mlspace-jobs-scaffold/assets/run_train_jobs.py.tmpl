"""Submit {{PROJECT_NAME}} training jobs to MLSpace — one async job per experiment.

Each job is idempotent and dedup-safe:
  * skip if the experiment's artifacts already exist (unless --force);
  * skip if a job with the same normalized description is already queued/running.

The repo is staged to an out-of-workdir directory keyed by commit hash before
launch, so editing your working tree can never perturb an in-flight job.

Reuses the shared ``mls`` library for API access, in-progress listing and
quota-aware submission — this script is a *consumer* of mls, never a modifier.

    python scripts/run_train_jobs.py --author_name you --telegram_nick you --dry
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shlex
import shutil
import subprocess
import sys

# Shared mls library (read-only consumer). See references/mls-helpers.md.
from mls.manager.job.utils import (
    get_in_progress_jobs,
    run_job_with_retry,
    training_job_api_from_profile,
)

# Secret-masking for --dry payload printing comes from mls. Fallback keeps a
# freshly scaffolded repo working if its pinned mls predates the redact module.
try:
    from mls.manager.job.redact import redact_payload
except ImportError:  # pragma: no cover - older mls without redact module

    def redact_payload(payload: dict, *, hints=("TOKEN", "SECRET", "KEY", "PASSWORD")):
        env = dict(payload.get("env_variables", {}))
        for k, v in env.items():
            if v and any(h in k.upper() for h in hints):
                env[k] = "<redacted>"
        return {**payload, "env_variables": env}


from experiments import (  # adjust import path to your package layout
    INSTANCE_TYPES_BY_NUM_GPUS,
    build_train_command,
    collect_experiments,
    has_training_artifacts,
)

# --- Absolute, out-of-workdir locations (see references/artifacts-layout.md) --
# All derive from /home/jovyan/{{PROJECT_SLUG}}-artifacts/ — normally a symlink
# to the storage target chosen at scaffold time (or a plain dir if no symlink).
# INSTANCE_TYPES_BY_NUM_GPUS lives in experiments.py (the single per-project
# source of truth, populated from `mls job instance_types` at scaffold time).
ARTIFACTS_ROOT = "{{ARTIFACTS_ROOT}}"          # /home/jovyan/{{PROJECT_SLUG}}-artifacts/training/artifacts
ARTIFACTS_ROOT_SANITY = "{{ARTIFACTS_ROOT_SANITY}}"  # …/training/artifacts_sanity_check
STAGING_ROOT = "{{STAGING_ROOT}}"              # /home/jovyan/{{PROJECT_SLUG}}-artifacts/code
BASE_IMAGE = "cr.ai.cloud.ru/aicloud-base-images/py3.12-torch2.7.0:0.0.41"
HF_HOME = "{{HF_HOME}}"                         # shared HF cache on NFS

_JOB_DESC_TAG_RE = re.compile(r"[#@]\S+")


def normalize_job_desc(desc: str) -> str:
    """Strip #tags/@mentions so dedup matches on the description body only."""
    return " ".join(_JOB_DESC_TAG_RE.sub("", desc).split())


# --- git / staging: clone code to a stable dir so live edits are isolated -----


def _git(repo_root: str, *args: str) -> str:
    return subprocess.run(
        ["git", "-C", repo_root, *args], capture_output=True, text=True, check=True
    ).stdout.strip()


def _dirty_tracked(repo_root: str) -> list[str]:
    lines = _git(repo_root, "status", "--porcelain").splitlines()
    return [ln for ln in lines if ln and not ln.startswith("??")]


def stage_repo(repo_root: str, target: str) -> None:
    """Copy .git + ``git reset --hard HEAD`` into target. Idempotent + atomic."""
    if os.path.isdir(target):
        print(f"Reusing staged repo at: {target}")
        return
    os.makedirs(os.path.dirname(target), exist_ok=True)
    tmp = f"{target}.tmp.{os.getpid()}"
    if os.path.exists(tmp):
        shutil.rmtree(tmp)
    os.makedirs(tmp)
    print(f"Staging {repo_root} -> {target}")
    subprocess.run(["cp", "-a", os.path.join(repo_root, ".git"), tmp], check=True)
    subprocess.run(["git", "-C", tmp, "reset", "--hard", "HEAD"], check=True)
    try:
        os.rename(tmp, target)
    except OSError:
        shutil.rmtree(tmp, ignore_errors=True)
        if not os.path.isdir(target):
            raise


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(description="Submit training jobs to MLSpace.")
    p.add_argument("--profile", default="default")
    p.add_argument("--base_image", default=BASE_IMAGE)
    p.add_argument("--author_name", required=True, help="Author tag in job_desc.")
    p.add_argument("--telegram_nick", required=True, help="Telegram nick in job_desc.")
    p.add_argument("--dry", action="store_true", help="Print payloads, do not launch.")
    p.add_argument("--force", action="store_true", help="Launch even if artifacts exist.")
    p.add_argument("--sanity_check", "--sanity-check", action="store_true")
    p.add_argument("--filter", default=None, help="Substring filter on experiment name.")
    return p.parse_args()


def main() -> int:
    args = parse_args()

    # Resolve the repo root robustly regardless of where the launcher lives
    # (repo root, scripts/, etc.) — no fragile parent-of-cwd assumption.
    repo_root = _git(os.getcwd(), "rev-parse", "--show-toplevel")
    commit = _git(repo_root, "rev-parse", "HEAD")

    if not args.dry:
        dirty = _dirty_tracked(repo_root)
        if dirty:
            print(
                f"\033[31mWorking tree is dirty (HEAD={commit[:8]}). Commit or "
                f"stash first — staging materializes from .git, so uncommitted "
                f"changes would be silently dropped.\033[0m",
                file=sys.stderr,
            )
            print("\n".join(dirty), file=sys.stderr)
            return 1
        staged_repo = os.path.join(STAGING_ROOT, commit)
        stage_repo(repo_root, staged_repo)
        staged_workdir = staged_repo  # + "/<subdir>" if your code lives in one
    else:
        # Dry mode: no staging, so the printed script references the live repo.
        staged_workdir = repo_root

    client, extra = training_job_api_from_profile(args.profile)
    in_progress = {
        normalize_job_desc(j.get("job_desc", "")) for j in get_in_progress_jobs()
    }

    artifacts_root = ARTIFACTS_ROOT_SANITY if args.sanity_check else ARTIFACTS_ROOT
    launched: list[dict] = []
    planned = 0

    for exp in collect_experiments(filter_name=args.filter):
        planned += 1
        output_dir = os.path.join(artifacts_root, exp.name)

        if has_training_artifacts(output_dir) and not args.force:
            print(f"\033[33mSkip (artifacts exist):\033[0m {output_dir}")
            continue

        cmd = build_train_command(
            exp, output_dir, sanity_check=args.sanity_check, write_config=not args.dry
        )
        script = (
            f"cd {shlex.quote(staged_workdir)}"
            ' && export PYTHONPATH="$WORKDIR:${PYTHONPATH:-}"'
            f" && {shlex.join(cmd)}"
        )

        description = exp.description or exp.name
        job_desc = f"🏋️ {description} #{args.author_name} @{args.telegram_nick}"
        if normalize_job_desc(job_desc) in in_progress:
            print(f"\033[33mSkip (already in queue):\033[0m {job_desc}")
            continue

        if exp.num_gpus not in INSTANCE_TYPES_BY_NUM_GPUS:
            print(f"\033[31mNo instance type for num_gpus={exp.num_gpus}\033[0m")
            return 1

        payload = {
            "script": script,
            "job_desc": job_desc,
            "env_variables": {
                "HF_HOME": HF_HOME,
                "HF_TOKEN": os.environ.get("HF_TOKEN", ""),
                "WORKDIR": staged_workdir,
            },
            "instance_type": INSTANCE_TYPES_BY_NUM_GPUS[exp.num_gpus],
            "region": extra["region"],
            "type": "binary_exp",
            "shm_size_class": "large",
            "base_image": args.base_image,
            "n_workers": 1,
            "processes_per_worker": 1,
            **({"priority_class": exp.priority_class} if exp.priority_class else {}),
        }

        print(f"\033[32mWould launch [{exp.num_gpus} GPU]:\033[0m {job_desc}")
        print(f"\033[90m  {script}\033[0m")
        if args.dry:
            # Print the full payload with secrets masked so the dry output is
            # both useful and safe to share.
            print(json.dumps(redact_payload(payload), indent=2))
            continue

        result = run_job_with_retry(client, payload, profile=args.profile)
        job_name = result.get("job_name") if isinstance(result, dict) else None
        if job_name:
            launched.append(
                {"job_name": job_name, "description": description, "num_gpus": exp.num_gpus}
            )
        print("result", result)

    print(f"Planned: {planned} | Launched: {len(launched)}")
    print("__TRAINING_JOBS_JSON__")
    print(json.dumps({"jobs": launched, "launched": len(launched)}))
    return 0


if __name__ == "__main__":
    sys.exit(main())
